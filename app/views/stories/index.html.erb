<div class="container mt-5 mb-3">
  <h2>Lees 'n bietjie: </h2>
</div>
<div class="container row justify-content-center gap-2 m-1">
  <% @stories.each do |story| %>
    <div class="card col-lg-3 col-md-4 col-sm-6 m-1 p-1 rounded-4">
      <div class="container">
        <%= image_tag 'Cat-on-couch.jpg', height: "120", width: "auto" %>
      </div>
      <div class="container">
        <%= link_to story.title, story_path(story), class: "ovo-regular link" %>
      </div>
    </div>
  <% end %>
</div>
