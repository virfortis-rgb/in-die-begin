<div class="container mt-3">
  <%= link_to stories_path, class: "back-link" do %>
    <i class="fa-solid fa-chevron-left me-1"></i>Back
  <% end %>
  <h2 class="my-3">
    <%= @story.title %>
  </h2>
  <div class="card p-2">
    <div>
      <% @vocabs.each do |vocab| %>
        <%= link_to vocab.word.name, "#", class: "btn btn-primary rounded-4 m-1", data: { bs_toggle: "modal", bs_target: "#vocabModal#{vocab.id}" } %>
        <%= render 'vocab/new', vocab: vocab %>
      <% end %>
    </div>
  </div>
</div>
