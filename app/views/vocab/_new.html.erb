<div class="modal fade" id="vocabModal<%= vocab.id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Modal title</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p><%= vocab.word.name %></p>
        <div class="container">
          <% vocab.word.definitions.each do |definition| %>
            <p><%= definition %></p>
          <% end %>
          <p>Dan moet jy Word en Storie gebruik om 'n nuwe Vocab te maak as daar save geklink word</p>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Maak toe</button>
        <button type="button" class="btn btn-primary">Onthou <strong>die vocab.word</strong></button>
      </div>
    </div>
  </div>
</div>
